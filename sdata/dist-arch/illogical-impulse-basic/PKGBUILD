groups=(illogical-impulse)
pkgname=illogical-impulse-basic
pkgver=1.0
pkgrel=3
pkgdesc='Illogical Impulse Basic Dependencies'
arch=(any)
license=(None)
depends=(
  bc
  coreutils
  cliphist
  cmake
  curl
  wget
  ripgrep
  jq
  xdg-user-dirs
  # Used in install script
  rsync
  go-yq # https://github.com/mikefarah/yq
  # Required by the AI Usage sidebar tab: ccusage runs via `npx ccusage@latest`
  # to report Claude Code spend (tokens × price). nodejs/npm provide the npx
  # runtime. The AUR package `ccusage` (maintainer: ggilestro, v20.0.14-1, not
  # out-of-date as of 2026-06-20) can also be declared here as an alternative to
  # the on-demand npx fetch; however, since it is an AUR package (not official
  # repos) and PKGBUILD depends must be pacman-resolvable, we rely on npx and
  # declare only the Node runtime. Install ccusage from AUR for offline use:
  #   yay -S ccusage
  nodejs
  npm
  # Required by AntigravityUsage.qml: secret-tool reads the Antigravity bearer
  # token from the OS keyring at runtime. libsecret provides the secret-tool
  # binary. Without it the Antigravity section shows a "install libsecret" hint.
  libsecret
  # curl and jq are reused by OpenAiUsage.qml (Codex quota fetch + token
  # aggregation from ~/.codex/sessions rollout files). They are already listed
  # above but noted here for traceability. OpenAiUsage.qml uses `find`
  # (coreutils) for rollout discovery — NOT fd — so no new dep is added there.
  # Required by OpenCodeUsage.qml: sqlite3 CLI reads the OpenCode spend DB at
  # ~/.local/share/opencode/opencode.db. The `sqlite` package provides sqlite3.
  sqlite
)
